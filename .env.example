# Copy to `.env.local` for local dev. Production values live in Vercel project
# settings → Environment Variables. Never commit real secrets.

# --- Supabase (primary data store) -------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Stripe (paywall) --------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
SITE_URL=

# --- Admin panel (server-checked) --------------------------------------------
# Used by api/admin-auth.js to gate the admin modal in App.jsx.
ADMIN_PASSWORD=

# --- Room tokens (DO NOT ROTATE without invalidating existing rooms) ---------
# Historical name; serves only as the HMAC salt seed for room owner /
# participant tokens. See README for the migration path to ROOM_TOKEN_SECRET.
GOOGLE_WEBHOOK_SECRET=
# Optional explicit override for the room HMAC key.
ROOM_TOKEN_SECRET=
